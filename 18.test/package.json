{
    "name": "12.express",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "start": "cross-env NODE_ENV=prod node ./src/index.ts",
        "dev": "node --watch --env-file=.env ./src/index.ts",
        "ts:check": "tsc --noEmit",
        "seed:dev": "prisma db seed",
        "_comment:1": "llama a  node --env-file=.env ./src/config/db.seed.ts",
        "db:push:test": "prisma db push --config prisma.test.config.ts",
        "db:seed:test": "prisma db seed --config prisma.test.config.ts",
        "seed:test": "npm run db:push:test && npm run db:seed:test",
        "_comment:2": "llama a  node --env-file=.env.test ./src/config/db-test.seed.ts",
        "test": "node --env-file=.env.test --test",
        "test:serie": "node --env-file=.env.test --test --test-concurrency=1"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "module",
    "dependencies": {
        "debug": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/debug": "^4.1.13",
        "@types/node": "^25.5.0",
        "eslint": "^10.0.3",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.0"
    },
    "prettier": {
        "singleQuote": true
    }
}
